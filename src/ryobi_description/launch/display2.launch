<launch>
  <arg
    name="model" />
  <param
    name="robot_description"
    textfile="$(find ryobi_description)/urdf/ryobi_description.urdf" />
     <param name="namespace" value="ryobi1" />
     <param name="tf_prefix" value="ryobi1" />
  <node
    name="joint_state_publisher"
    pkg="joint_state_publisher"
    type="joint_state_publisher" />
  <node
    name="robot_state_publisher"
    pkg="robot_state_publisher"
    type="robot_state_publisher" />
  <node
    name="rviz"
    pkg="rviz"
    type="rviz"
    args="-d $(find ryobi_description)/urdf/ryobi.rviz" />
      


     
     <!--Zed odom tf to ryobi1/odom       -->   
          <node name="ryobi_zed_odom_tf" pkg="kangal_utopia" type="ryobi_zed_odom_tf.py" output="screen"/>

        
               <!--Zed imu tf to ryobi1/imu   
          <node name="ryobi_zed_imu_tf" pkg="kangal_utopia" type="ryobi_zed_imu_tf.py" output="screen"/>

 -->
</launch>
